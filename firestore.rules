rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Players collection: clients can read/write their OWN document. The
    // draw / upgrade / autosave paths today run the engine CLIENT-SIDE and
    // write the result here directly. Anti-cheat field-locks (shields,
    // coins, etc.) were attempted but break those flows — proper anti-cheat
    // needs the client to call the executeDraw / executeUpgrade Cloud
    // Functions instead of writing the snapshot itself. Tracked as
    // follow-up; today's rule mirrors the pre-shields baseline.
    match /players/{playerId} {
      allow read: if request.auth != null && request.auth.uid == playerId;
      allow write: if request.auth != null && request.auth.uid == playerId;

      match /impacts/{impactId} {
        allow read: if request.auth != null && request.auth.uid == playerId;
        allow write: if false;
      }
    }

    // Voodoo steal sessions — created/updated only by Cloud Functions (Admin SDK).
    // The thief reads to display session state; no one writes from the client.
    match /stealSessions/{sessionId} {
      allow read: if request.auth != null && resource.data.thiefId == request.auth.uid;
      allow write: if false;
    }

    // Default deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
