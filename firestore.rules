rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Players collection: clients can ONLY READ their own document.
    // ALL writes must go through Callable Cloud Functions which use Admin SDK
    // (Admin SDK bypasses these rules by design).
    match /players/{playerId} {
      allow read: if request.auth != null && request.auth.uid == playerId;
      allow write: if false;

      match /impacts/{impactId} {
        allow read: if request.auth != null && request.auth.uid == playerId;
        allow write: if false;
      }
    }

    // Default deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
