rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Players collection: clients can read/write their OWN document. Cross-player
    // writes (e.g. voodoo steal mutating the victim) still go through Cloud Functions
    // using Admin SDK, which bypasses these rules by design.
    //
    // TODO: once draw + upgrade are migrated to Cloud Functions too, revert this back
    //       to "allow write: if false" so the client never writes directly.
    match /players/{playerId} {
      allow read: if request.auth != null && request.auth.uid == playerId;
      allow write: if request.auth != null && request.auth.uid == playerId;

      match /impacts/{impactId} {
        allow read: if request.auth != null && request.auth.uid == playerId;
        allow write: if false;
      }
    }

    // Voodoo steal sessions — created/updated only by Cloud Functions (Admin SDK).
    // The thief reads to display session state; no one writes from the client.
    match /stealSessions/{sessionId} {
      allow read: if request.auth != null && resource.data.thiefId == request.auth.uid;
      allow write: if false;
    }

    // Default deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
